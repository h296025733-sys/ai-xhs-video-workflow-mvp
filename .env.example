# 本文件只放示例值。复制为 .env 后再填写自己的本机配置，不要提交 .env。

APP_ENV=local
PYTHONIOENCODING=utf-8

# FastAPI 服务地址
API_BASE_URL=http://127.0.0.1:8004

# FFmpeg，可留空使用系统 PATH
FFMPEG_PATH=
FFPROBE_PATH=

# XHS-Downloader，可选
XHS_DOWNLOAD_MODE=disabled
XHS_DOWNLOADER_API_BASE_URL=http://127.0.0.1:5556
XHS_DOWNLOADER_PROJECT_DIR=D:\workspace\your-XHS-Downloader
XHS_DOWNLOADER_CLI_PATH=YOUR_XHS_DOWNLOADER_PATH
XHS_CREATOR_IMPORT_MODE=manual_links

# 小红书作者主页浏览器自动化，可选
# 用已登录 Chrome 的远程调试端口，让脚本复用你的浏览器登录态。
XHS_CDP_URL=http://127.0.0.1:9222
XHS_AUTHOR_CACHE_PATH=D:\workspace\your-project\.runtime\xhs_author_profile_cache.json

# 小红书登录态只允许本机使用，不能提交真实值
XHS_COOKIE=YOUR_XHS_COOKIE_HERE
XHS_WEB_SESSION=YOUR_XHS_WEB_SESSION_HERE

# 输出目录，建议保留在本地并通过 .gitignore 排除
VIDEO_DELIVERY_DIR=D:\workspace\your-project\outputs
XHS_REPORT_DIR=D:\workspace\your-project\outputs\reports
XHS_TEMP_DIR=D:\workspace\your-project\.runtime\xhs_direct_v2
XHS_LINK_DIR=D:\workspace\your-project\.runtime\xhs_author_links

# OpenClaw / 企业 IM 示例
OPENCLAW_GATEWAY_URL=YOUR_OPENCLAW_GATEWAY_URL
DINGTALK_WEBHOOK_TOKEN=YOUR_DINGTALK_TOKEN_HERE
FEISHU_APP_ID=YOUR_FEISHU_APP_ID_HERE
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET_HERE

# 模型服务示例，如后续接入 AI 文案/审核
MODEL_PROVIDER=YOUR_MODEL_PROVIDER
MODEL_NAME=YOUR_MODEL_NAME
API_KEY=YOUR_API_KEY_HERE
